{
  "info": {
    "name": "Contact Management System API",
    "description": "TechnoHacks Internship - Advanced Level Task.\n\nSpring Boot 3 + PostgreSQL REST API for managing contacts. Covers full CRUD plus search and category filtering.\n\nBefore running:\n1. Start PostgreSQL and create the `contact_management_db` database.\n2. Run the Spring Boot app (`mvn spring-boot:run`), which listens on `http://localhost:8080`.\n3. Run requests top to bottom in the 'Happy Path' folder once, in order, since later requests in that folder reuse the `contactId` saved from the create request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/contacts",
      "type": "string"
    },
    {
      "key": "contactId",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the 'Create Contact' request's test script."
    }
  ],
  "item": [
    {
      "name": "Happy Path (run in order)",
      "item": [
        {
          "name": "1. Create Contact",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has an id\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    pm.collectionVariables.set(\"contactId\", body.id);",
                  "});",
                  "",
                  "pm.test(\"Response echoes submitted fields\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.name).to.eql(\"Aarav Kapoor\");",
                  "    pm.expect(body.phoneNumber).to.eql(\"9876512340\");",
                  "    pm.expect(body.category).to.eql(\"Work\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Aarav Kapoor\",\n    \"phoneNumber\": \"9876512340\",\n    \"email\": \"aarav.kapoor@example.com\",\n    \"address\": \"Pune, Maharashtra\",\n    \"category\": \"Work\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Creates a new contact. Saves the returned id into the `contactId` collection variable for use by later requests in this folder."
          }
        },
        {
          "name": "2. Get All Contacts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array containing at least one contact\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "    pm.expect(body.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Returns every contact, sorted alphabetically by name."
          }
        },
        {
          "name": "3. Get Contact By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Returned contact matches the saved id\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(String(body.id)).to.eql(pm.collectionVariables.get(\"contactId\"));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{contactId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{contactId}}"]
            },
            "description": "Fetches the single contact created in step 1, by its id."
          }
        },
        {
          "name": "4. Update Contact",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Fields reflect the update\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.category).to.eql(\"Personal\");",
                  "    pm.expect(body.address).to.eql(\"Mumbai, Maharashtra\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Aarav Kapoor\",\n    \"phoneNumber\": \"9876512340\",\n    \"email\": \"aarav.kapoor@example.com\",\n    \"address\": \"Mumbai, Maharashtra\",\n    \"category\": \"Personal\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{contactId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{contactId}}"]
            },
            "description": "Updates the contact created in step 1 -- changes the address and category."
          }
        },
        {
          "name": "5. Search Contacts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Search finds the contact by partial name\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.some(c => c.name.includes(\"Aarav\"))).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search?term=Aarav",
              "host": ["{{baseUrl}}"],
              "path": ["search"],
              "query": [{ "key": "term", "value": "Aarav" }]
            },
            "description": "Case-insensitive search across name, phone number, and email."
          }
        },
        {
          "name": "6. Get Contacts By Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"All returned contacts have the requested category\", function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(c => pm.expect(c.category.toLowerCase()).to.eql(\"personal\"));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/category/Personal",
              "host": ["{{baseUrl}}"],
              "path": ["category", "Personal"]
            },
            "description": "Filters contacts by category (case-insensitive)."
          }
        },
        {
          "name": "7. Delete Contact",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response confirms deletion\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.include(pm.collectionVariables.get(\"contactId\"));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{contactId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{contactId}}"]
            },
            "description": "Deletes the contact created in step 1, cleaning up after this test run."
          }
        }
      ]
    },
    {
      "name": "Validation & Error Cases",
      "item": [
        {
          "name": "Create Contact - Missing Name (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Error mentions the name field\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(JSON.stringify(body.details)).to.include(\"name\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"\",\n    \"phoneNumber\": \"9876500000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Name is blank, which should fail @NotBlank validation and return 400 with field-level detail."
          }
        },
        {
          "name": "Create Contact - Invalid Phone Number (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test User\",\n    \"phoneNumber\": \"call-me-maybe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Phone number doesn't match the digits-only pattern, should fail @Pattern validation."
          }
        },
        {
          "name": "Create Contact - Duplicate Phone Number (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 409 Conflict\", function () {",
                  "    pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Duplicate Tester\",\n    \"phoneNumber\": \"9876512340\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Run this AFTER 'Happy Path > 1. Create Contact' (and before deleting it) -- 9876512340 will already exist, so this should return 409."
          }
        },
        {
          "name": "Get Contact By Id - Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 404 Not Found\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test(\"Error message mentions the id\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.message).to.include(\"999999\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/999999",
              "host": ["{{baseUrl}}"],
              "path": ["999999"]
            },
            "description": "999999 should never exist, so this should return 404 with a clear message."
          }
        },
        {
          "name": "Update Contact - Not Found (404)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Ghost\",\n    \"phoneNumber\": \"9000000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/999999",
              "host": ["{{baseUrl}}"],
              "path": ["999999"]
            },
            "description": "Updating a non-existent id should return 404, not silently create one."
          }
        },
        {
          "name": "Delete Contact - Not Found (404)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/999999",
              "host": ["{{baseUrl}}"],
              "path": ["999999"]
            },
            "description": "Deleting a non-existent id should return 404."
          }
        }
      ]
    },
    {
      "name": "Standalone Examples",
      "item": [
        {
          "name": "Create Contact - Minimal Fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Minimal Contact\",\n    \"phoneNumber\": \"9000011111\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Only the required fields (name, phoneNumber). Email/address are optional, category defaults server-side to 'General'."
          }
        },
        {
          "name": "Create Contact - International Phone Format",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Global Contact\",\n    \"phoneNumber\": \"+919876512399\",\n    \"email\": \"global@example.com\",\n    \"category\": \"Friends\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": ["{{baseUrl}}"]
            },
            "description": "Phone numbers may optionally start with a '+' for international format."
          }
        }
      ]
    }
  ]
}
